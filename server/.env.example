NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/portfolio_builder
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
# Frontend origins allowed by CORS. Comma-separate if you intentionally use more than one.
FRONTEND_URL=http://localhost:5173
# When running behind Vercel or another reverse proxy, keep this at 1 unless you have a different hop count.
TRUST_PROXY=1

# Gmail SMTP (for OTP and contact notifications)
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ADMIN_CONTACT_EMAIL=admin@example.com

# Google OAuth
# This single web client id is used by both backend verification and the frontend Google button.
# Add your frontend origin(s) to Authorized JavaScript origins in Google Cloud.
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Vercel deployment API
VERCEL_TOKEN=your_vercel_token
VERCEL_PROJECT_ID=your_vercel_project_id
VERCEL_TEAM_ID=
